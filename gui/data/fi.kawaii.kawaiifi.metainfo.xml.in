<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <name>KawaiiFi</name>
  <summary>Wi-Fi network scanner</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      KawaiiFi scans nearby Wi-Fi networks and displays their signal strength,
      channels, security modes, supported protocols, and advertised 802.11
      capabilities.
    </p>
    <p>
      It can filter scan results by SSID, BSSID, vendor, band, security,
      channel width, protocol, and amendment.
    </p>
  </description>

  <screenshots>
    <screenshot type="default">
      <caption>Main window showing nearby Wi-Fi BSSs</caption>
      <image>https://raw.githubusercontent.com/zleytus/kawaiifi/kawaiifi-gui-v0.1.0/gui/data/screenshots/01-main-window-bss-table.png</image>
    </screenshot>
    <screenshot>
      <caption>Filters for narrowing scan results</caption>
      <image>https://raw.githubusercontent.com/zleytus/kawaiifi/kawaiifi-gui-v0.1.0/gui/data/screenshots/02-filters.png</image>
    </screenshot>
    <screenshot>
      <caption>Information elements for a selected BSS</caption>
      <image>https://raw.githubusercontent.com/zleytus/kawaiifi/kawaiifi-gui-v0.1.0/gui/data/screenshots/03-information-elements.png</image>
    </screenshot>
    <screenshot>
      <caption>List of Wi-Fi interfaces that can be selected for performing scans</caption>
      <image>https://raw.githubusercontent.com/zleytus/kawaiifi/kawaiifi-gui-v0.1.0/gui/data/screenshots/04-interfaces.png</image>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <categories>
    <category>Network</category>
    <category>Monitor</category>
  </categories>

  <url type="homepage">https://kawaii.fi</url>
  <url type="bugtracker">https://github.com/zleytus/kawaiifi/issues</url>
  <url type="vcs-browser">https://github.com/zleytus/kawaiifi</url>

  <developer id="io.github.zleytus">
    <name>Zach Leytus</name>
  </developer>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.0" date="2026-06-04">
      <description>
        <p>
          Initial release with Wi-Fi scanning, filtering, BSS details,
          information element inspection, charting, and scan file import/export.
        </p>
      </description>
    </release>
  </releases>
</component>
