<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Kawaiifi.Net</PackageId>
    <Version>0.1.0</Version>
    <Authors>Zach Leytus</Authors>
    <Description>A Wi-Fi scanning library for Linux, macOS, and Windows.</Description>
    <Copyright>Copyright (c) 2026 Zach Leytus</Copyright>
    <PackageLicenseExpression>MIT OR Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/zleytus/kawaiifi</RepositoryUrl>
    <PackageProjectUrl>https://github.com/zleytus/kawaiifi</PackageProjectUrl>
    <PackageTags>wifi;wi-fi;wireless;scanning;802.11;native-wifi;nl80211</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="README.md" />
    <None Include="../../LICENSE-MIT" Pack="true" PackagePath="\" />
    <None Include="../../LICENSE-APACHE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="../../ffi/include/NativeMethods.g.cs" />
    <Compile Include="../../ffi/include/NativeMethods.Linux.g.cs" />
    <Compile Include="../../ffi/include/NativeMethods.MacOS.g.cs" />
    <Compile Include="../../ffi/include/NativeMethods.Windows.g.cs" />
    <Compile Include="../../ffi/include/NativeTypes.cs" />
  </ItemGroup>

  <!-- Copy native library to output directory for local development -->
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux')) And Exists('../../target/release/libkawaiifi.so')">
    <Content Include="../../target/release/libkawaiifi.so">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>false</Pack>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX')) And Exists('../../target/release/libkawaiifi.dylib')">
    <Content Include="../../target/release/libkawaiifi.dylib">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>false</Pack>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows')) And Exists('../../target/release/kawaiifi.dll')">
    <Content Include="../../target/release/kawaiifi.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Pack>false</Pack>
    </Content>
  </ItemGroup>

  <!-- Include native libraries in NuGet package when provided via CI -->
  <ItemGroup Condition="'$(NativeLinuxX64)' != ''">
    <None Include="$(NativeLinuxX64)" Pack="true" PackagePath="runtimes/linux-x64/native/" />
  </ItemGroup>

  <ItemGroup Condition="'$(NativeMacOSArm64)' != ''">
    <None Include="$(NativeMacOSArm64)" Pack="true" PackagePath="runtimes/osx-arm64/native/" />
  </ItemGroup>

  <ItemGroup Condition="'$(NativeWindowsX64)' != ''">
    <None Include="$(NativeWindowsX64)" Pack="true" PackagePath="runtimes/win-x64/native/" />
  </ItemGroup>


</Project>
