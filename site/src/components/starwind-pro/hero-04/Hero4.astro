---
import IconArrowRight from "@tabler/icons/outline/arrow-right.svg";
import IconSparkles from "@tabler/icons/outline/sparkles.svg";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { Button } from "@/components/starwind/button";

interface Props extends HTMLAttributes<"section"> {
  /** Badge text */
  badgeText?: string;
  /** Badge href */
  badgeHref?: string;
  /** Badge icon component */
  badgeIcon?: any;
  /** Main heading text */
  heading?: string;
  /** Description text */
  description?: string;
  /** Primary button text */
  primaryButtonText?: string;
  /** Primary button href */
  primaryButtonHref?: string;
  /** Secondary button text */
  secondaryButtonText?: string;
  /** Secondary button href */
  secondaryButtonHref?: string;
}

const hero4Styles = tv({
  base: "dark bg-background text-foreground @container relative mx-auto w-full overflow-hidden px-4 py-24",
});

const {
  badgeText = "Introducing Starwind Pro",
  badgeHref = "#",
  badgeIcon: BadgeIcon = IconSparkles,
  heading = "Build Beautiful Websites with Starwind Pro",
  description = "Create stunning, responsive websites with our modern component library. Get started in minutes and ship faster than ever before.",
  primaryButtonText = "Get Started",
  primaryButtonHref = "#",
  secondaryButtonText,
  secondaryButtonHref = "#",
  class: className,
  ...rest
} = Astro.props;
---

<section class={hero4Styles({ class: className })} {...rest}>
  <!-- Grid Background -->
  <div class="text-muted-foreground pointer-events-none absolute inset-0" aria-hidden="true">
    <svg class="size-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-04-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path
            d="M40 0v40M0 40h40"
            fill="none"
            stroke="currentColor"
            opacity="0.8"
            stroke-width="0.5"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-04-grid)"></rect>
    </svg>
    <div class="via-background/50 to-background absolute inset-0 bg-linear-to-b from-transparent">
    </div>
  </div>

  <!-- Content -->
  <div class="relative mx-auto flex max-w-4xl flex-col items-center text-center">
    <a
      href={badgeHref}
      class="bg-muted text-muted-foreground hover:text-foreground hover:border-foreground/40 mb-6 flex items-center gap-2 rounded-full border px-3 py-0.5 text-sm transition-colors"
    >
      <BadgeIcon class="size-4" />
      <span>{badgeText}</span>
    </a>
    <h1
      class="from-foreground to-foreground/60 bg-linear-to-br bg-clip-text text-4xl font-medium tracking-tight text-transparent @lg:text-5xl @xl:text-6xl"
    >
      {heading}
    </h1>
    <p class="text-muted-foreground mt-6 max-w-2xl text-lg text-pretty @lg:text-xl">
      {description}
    </p>
    <div class="mt-8 flex w-full flex-col gap-4 @md:w-auto @md:flex-row">
      <Button class="w-full @md:w-auto" href={primaryButtonHref}>{primaryButtonText}</Button>
      {
        secondaryButtonText && (
          <Button variant="outline" class="group w-full @md:w-auto" href={secondaryButtonHref}>
            {secondaryButtonText}{" "}
            <IconArrowRight class="transition-transform group-hover:translate-x-1" />
          </Button>
        )
      }
    </div>
  </div>
</section>
