---
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { AspectRatio } from "@/components/starwind/aspect-ratio";
import { Image } from "@/components/starwind/image";
import Effect7 from "@/components/starwind-pro/effect-07/Effect7.astro";

/** Feature card configuration */
export interface FeatureCard {
    /** Card title */
    title: string;
    /** Card description */
    description: string;
    /** Icon component (SVG) - use either icon or image */
    icon?: astroHTML.JSX.Element;
    /** Image URL - use either icon or image */
    image?: string;
    /** Image alt text */
    imageAlt?: string;
}

interface Props extends HTMLAttributes<"section"> {
    /** Badge/eyebrow text */
    badge?: string;
    /** Section heading */
    heading?: string;
    /** Section description */
    description?: string;
    /** Array of feature cards (expects 2) */
    features?: FeatureCard[];
}

const sectionStyles = tv({
    base: "@container mx-auto w-full max-w-6xl px-4 py-24",
});

const {
    badge,
    heading = "Built for modern teams",
    description,
    features = [],
    class: className,
    ...rest
} = Astro.props;
---

<section class={sectionStyles({ class: className })} {...rest}>
    <div class="mb-16">
        {
            badge && (
                <p class="text-primary-accent mb-3 text-sm font-medium">
                    {badge}
                </p>
            )
        }
        <h2
            class="font-heading mb-4 text-3xl font-semibold tracking-tight @xl:text-4xl @3xl:text-5xl"
        >
            {heading}
        </h2>
        {
            description && (
                <p class="text-muted-foreground mt-4 text-pretty @xl:text-lg">
                    {description}
                </p>
            )
        }
    </div>

    <div class="grid gap-4 @xl:grid-cols-2">
        {
            features.map((feature) => (
                <Effect7
                    cornerLength={24}
                    borderWidth={3}
                    class="bg-card group h-full p-8"
                >
                    {/* Media - Icon or Image */}
                    {feature.icon && (
                        <div class="bg-primary-accent/10 text-primary-accent mb-6 inline-flex size-14 items-center justify-center">
                            <feature.icon class="size-7" />
                        </div>
                    )}
                    {feature.image && (
                        <div class="mb-6 overflow-hidden">
                            <AspectRatio ratio={16 / 9}>
                                <Image
                                    src={feature.image}
                                    alt={feature.imageAlt || feature.title}
                                    class="size-full object-cover"
                                    loading="lazy"
                                />
                            </AspectRatio>
                        </div>
                    )}

                    {/* Content */}
                    <h3 class="font-heading text-xl font-semibold">
                        {feature.title}
                    </h3>
                    <p class="text-muted-foreground mt-3 text-pretty">
                        {feature.description}
                    </p>
                </Effect7>
            ))
        }
    </div>
</section>
