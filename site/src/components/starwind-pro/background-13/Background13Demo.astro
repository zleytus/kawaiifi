---
/**
 * Radial Grid Background
 *
 * A grid pattern with radial fade-out effect that focuses attention on the center.
 * Perfect for hero sections where content should be the focal point.
 *
 * Usage:
 * 1. Use the starwind cli to add this component to your project `npx starwind@latest add @starwind-pro/background-13`
 * 2. Import the `Background13` component and position it absolutely within a relative container
 *
 * Props:
 * - patternId: string (auto-generated) - Custom pattern ID for SVG reference
 * - cellSize: number (default: 40) - Grid cell size in pixels
 * - opacity: number (default: 0.3) - Stroke opacity (0-1)
 * - class: string - Additional CSS classes
 */
import Background13 from "./Background13.astro";
---

<div class="bg-background relative flex min-h-[500px] w-full items-center justify-center">
  <Background13 />
  <div class="relative z-10 text-center">
    <h2 class="text-foreground text-2xl font-semibold">Radial Grid</h2>
    <p class="text-muted-foreground mt-2">Grid pattern with radial fade-out effect</p>
    <p class="text-muted-foreground mt-4 text-sm">Customize cell size and opacity</p>
  </div>
</div>
