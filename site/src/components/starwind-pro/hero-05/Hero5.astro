---
import IconArrowRight from "@tabler/icons/outline/arrow-right.svg";
import IconDownload from "@tabler/icons/outline/download.svg";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { AspectRatio } from "@/components/starwind/aspect-ratio";
import { Button } from "@/components/starwind/button";

interface Props extends HTMLAttributes<"section"> {
  /** Main heading text */
  heading?: string;
  /** Description text */
  description?: string;
  /** Primary button text */
  primaryButtonText?: string;
  /** Primary button href */
  primaryButtonHref?: string;
  /** Show a download icon on the primary button */
  primaryButtonDownloadIcon?: boolean;
  /** Secondary button text */
  secondaryButtonText?: string;
  /** Secondary button href */
  secondaryButtonHref?: string;
  /** Image configuration */
  image?: {
    src: string;
    alt: string;
  };
}

const hero5Styles = tv({
  base: "@container mx-auto w-full max-w-6xl px-4 py-24",
});

const {
  heading = "The Modern Way to Build Your Next Project",
  description = "Experience the power of cutting-edge technology with an intuitive interface. Build faster, scale easier, and deliver exceptional results every time.",
  primaryButtonText = "Start Free Trial",
  primaryButtonHref = "#",
  primaryButtonDownloadIcon = false,
  secondaryButtonText,
  secondaryButtonHref = "#",
  image = {
    src: "https://images.unsplash.com/photo-1551434678-e076c223a692?w=1200&auto=format&fit=crop&q=80",
    alt: "Team collaboration workspace",
  },
  class: className,
  ...rest
} = Astro.props;
---

<section class={hero5Styles({ class: className })} {...rest}>
  <!-- Content -->
  <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
    <h1
      class="font-heading text-3xl font-medium tracking-tight text-pretty @xl:text-4xl @3xl:text-5xl"
    >
      {heading}
    </h1>
    <p class="text-muted-foreground mt-6 max-w-2xl text-pretty @xl:text-lg">
      {description}
    </p>
    <div class="mt-8 flex w-full flex-wrap gap-3 @md:w-fit">
      <Button variant="primary" class="w-full @md:w-auto" href={primaryButtonHref}>
        {primaryButtonDownloadIcon && <IconDownload />}
        {primaryButtonText}
      </Button>
      {
        secondaryButtonText && (
          <Button variant="outline" class="group w-full @md:w-auto" href={secondaryButtonHref}>
            {secondaryButtonText}{" "}
            <IconArrowRight class="transition-transform group-hover:translate-x-1" />
          </Button>
        )
      }
    </div>
  </div>

  <!-- Image -->
  <div class="mt-16">
    <AspectRatio ratio={16 / 9} class="overflow-hidden rounded-xl shadow-lg">
      <img src={image.src} alt={image.alt} class="size-full object-cover" />
    </AspectRatio>
  </div>
</section>
