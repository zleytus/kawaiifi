---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/starwind-pro/hero-05/Hero5.astro";
import Feature19, {
    type FeatureCard,
} from "@/components/starwind-pro/feature-19/Feature19.astro";
import Background13 from "../components/starwind-pro/background-13/Background13.astro";
import Navbar, {
    type NavLink,
} from "../components/starwind-pro/navbar-02/Navbar2.astro";
import IconBolt from "@tabler/icons/outline/bolt.svg";
import IconCloud from "@tabler/icons/outline/cloud.svg";
import IconLock from "@tabler/icons/outline/lock.svg";

const links: NavLink[] = [
    { label: "Features", href: "#features" },
    { label: "Downloads", href: "#downloads" },
    {
        label: "API",
        children: [
            { label: "Rust", href: "#rust" },
            { label: "C#", href: "#csharp" },
            { label: "C", href: "#c" },
        ],
    },
];

const features: FeatureCard[] = [
    {
        icon: IconBolt,
        title: "Lightning Fast",
        description:
            "Edge caching and minimal JavaScript for instant page loads.",
    },
    {
        image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=450&fit=crop",
        imageAlt: "Analytics dashboard",
        title: "Real-time Analytics",
        description:
            "Track interactions with detailed dashboards and insights.",
    },
    {
        image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=450&fit=crop",
        imageAlt: "Team collaborating",
        title: "Team Collaboration",
        description: "Work together seamlessly with real-time updates.",
    },
    {
        icon: IconLock,
        title: "Enterprise Security",
        description: "SOC 2 compliant with end-to-end encryption.",
    },
    {
        icon: IconCloud,
        title: "Global CDN",
        description: "Content delivered from edge locations worldwide.",
    },
    {
        image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=450&fit=crop",
        imageAlt: "Dashboard metrics",
        title: "Custom Dashboards",
        description: "Build personalized views for your unique workflow.",
    },
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
    <Navbar
        siteName="KawaiiFi"
        links={links}
        ctaText="Get Started"
        ctaHref="#get-started"
        githubHref="https://github.com/zleytus/kawaiifi"
    />

    <div class="relative isolate overflow-hidden">
        <Background13 class="z-0" />

        <Hero
            class="relative z-10"
            heading="Wi-Fi scanning for Linux"
            description="KawaiiFi helps you discover and analyze the wireless networks around you."
            primaryButtonText="Download"
            primaryButtonDownloadIcon
        />
    </div>

    <Feature19
        badge="Capabilities"
        heading="Everything you need to scale"
        description="A comprehensive toolkit designed for modern development teams."
        features={features}
    />
</Layout>
